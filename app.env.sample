# rclone — environment variable reference
# Copy relevant lines to a .env file alongside docker-compose.yaml

# Timezone
TZ=America/New_York

# Service user/group IDs
SERVICE_USER=1000
SERVICE_GROUP=1000

# Hostname
BASE_HOST_NAME=${HOSTNAME}

# Remote control (rc) web GUI credentials
RC_USER=admin
RC_PASS=changeme_admin_password
